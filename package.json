// ═══════════════════════════════════════════════════════
// CARD
// ═══════════════════════════════════════════════════════
const Card = ({ page, index, currentPage, onNext, onPrev, total }) => {
  const isActive = index === currentPage;
  const isFlipped = index < currentPage;
  const isBehind = index > currentPage;
  const depth = isBehind ? index - currentPage : 0;

  return (
    <div style={{
      position: "absolute", width: "100%", height: "100%",
      transformOrigin: "top center",
      transition: "all 0.65s cubic-bezier(0.4, 0, 0.2, 1)",
      transform: isFlipped
        ? "rotateX(-95deg) translateY(-10px)"
        : `translateY(${depth * 4}px) scale(${1 - depth * 0.018})`,
      opacity: isFlipped ? 0 : isBehind ? Math.max(0.2, 1 - depth * 0.3) : 1,
      zIndex: total - index,
      pointerEvents: isActive ? "auto" : "none",
    }}>
      <div style={{
        width: "100%", height: "100%", background: "#111118",
        borderRadius: 16, border: "1px solid #1e1e2e",
        padding: page.isCover ? 0 : "18px 16px 14px",
        display: "flex", flexDirection: "column",
        overflow: "hidden", position: "relative",
        boxShadow: isActive
          ? "0 20px 60px rgba(0,0,0,0.5)"
          : "0 4px 20px rgba(0,0,0,0.3)",
      }}>
        {/* Top accent bar */}
        <div style={{
          position: "absolute", top: 0, left: 24, right: 24, height: 2,
          borderRadius: "0 0 2px 2px", zIndex: 3,
          background: page.isCover ? ACCENT : page.accent, opacity: 0.6,
        }} />

        {page.isCover ? (
          <CoverPage onNext={onNext} />
        ) : (
          <>
            <div style={{
              display: "flex", justifyContent: "space-between",
              alignItems: "flex-start", marginBottom: 8,
            }}>
              <div style={{
                fontFamily: "'DM Mono', monospace", fontSize: 10,
                letterSpacing: 2, color: "#999",
              }}>{page.tag}</div>
              <div style={{
                fontFamily: "'DM Mono', monospace", fontSize: 9,
                letterSpacing: 1, color: page.accent,
                padding: "3px 10px", borderRadius: 5,
                background: `${page.accent}15`, border: `1px solid ${page.accent}30`,
              }}>● {page.status}</div>
            </div>

            <div style={{
              fontFamily: "'Instrument Sans', sans-serif", fontSize: 28,
              fontWeight: 700, color: "#fff", lineHeight: 1.15,
              marginBottom: 6, letterSpacing: -0.5,
            }}>{page.title}</div>

            <div style={{
              fontFamily: "'Instrument Sans', sans-serif", fontSize: 13,
              lineHeight: 1.5, color: "#bbb", marginBottom: 12,
            }}>{page.desc}</div>

            <ThumbPhoto label={page.thumbLabel} accent={page.accent} bgImage={page.bgImage} />
            <StatRow stats={page.stats} />
            <MiniBarChart data={page.bars} accent={page.accent} label={page.barLabel} />

            <div style={{
              display: "flex", justifyContent: "space-between",
              fontFamily: "'DM Mono', monospace", fontSize: 9,
              color: "#777", letterSpacing: 1, margin: "8px 0 12px",
            }}>
              <span>SRC: {page.source}</span>
              <span>{page.updated}</span>
            </div>

            <a href={page.url} target="_blank" rel="noopener noreferrer" style={{
              display: "flex", alignItems: "center", justifyContent: "center",
              padding: "14px 0", background: page.accent, borderRadius: 10,
              fontFamily: "'Instrument Sans', sans-serif", fontSize: 14,
              fontWeight: 700, letterSpacing: 1.5, color: "#0a0a12",
              textDecoration: "none", textTransform: "uppercase",
              transition: "all 0.25s", cursor: "pointer",
            }}
              onMouseEnter={e => { e.currentTarget.style.opacity = "0.85"; e.currentTarget.style.transform = "translateY(-1px)"; }}
              onMouseLeave={e => { e.currentTarget.style.opacity = "1"; e.currentTarget.style.transform = "translateY(0)"; }}
            >{page.linkLabel}</a>

            <div style={{ display: "flex", gap: 8, marginTop: 10 }}>
              {index > 1 && <NavBtn onClick={onPrev}>← PREV</NavBtn>}
              {index < total - 1 ? (
                <NavBtn onClick={onNext}>NEXT →</NavBtn>
              ) : (
                <NavBtn onClick={() => onNext()}>↑ COVER</NavBtn>
              )}
            </div>
          </>
        )}
      </div>
    </div>
  );
};

// ═══════════════════════════════════════════════════════
// MAIN
// ═══════════════════════════════════════════════════════
export default function MIA() {
  const [page, setPage] = useState(0);
  const [introComplete, setIntroComplete] = useState(false);
  const touchY = useRef(null);
  const wheelLock = useRef(null);

  const next = useCallback(() => setPage(p => p < PAGES.length - 1 ? p + 1 : 0), []);
  const prev = useCallback(() => setPage(p => p > 0 ? p - 1 : p), []);

  const onTouchStart = e => { touchY.current = e.touches[0].clientY; };
  const onTouchEnd = e => {
    if (touchY.current === null) return;
    const d = touchY.current - e.changedTouches[0].clientY;
    if (d > 40) next(); if (d < -40) prev();
    touchY.current = null;
  };
  const onWheel = e => {
    if (wheelLock.current) return;
    wheelLock.current = setTimeout(() => { wheelLock.current = null; }, 700);
    if (e.deltaY > 15) next(); if (e.deltaY < -15) prev();
  };

  return (
    <div style={{
      minHeight: "100vh", background: "#09090f",
      display: "flex", flexDirection: "column",
      alignItems: "center", justifyContent: "center",
      padding: "16px", position: "relative", overflow: "hidden",
      userSelect: "none",
    }}>
      <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400;500&family=Instrument+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

      {/* Intro */}
      {!introComplete && <IntroSequence onComplete={() => setIntroComplete(true)} />}

      {/* Dot texture */}
      <div style={{
        position: "fixed", inset: 0, pointerEvents: "none", opacity: 0.25,
        backgroundImage: "radial-gradient(circle at 1px 1px, #ffffff06 1px, transparent 0)",
        backgroundSize: "32px 32px",
      }} />

      {/* Top pill nav */}
      <div style={{
        position: "fixed", top: 14, left: 0, right: 0,
        display: "flex", justifyContent: "center", alignItems: "center",
        gap: 6, zIndex: 100,
        opacity: introComplete ? 1 : 0, transition: "opacity 0.5s ease",
      }}>
        {PAGES.map((p, i) => (
          <button key={p.id} onClick={() => setPage(i)} style={{
            width: i === page ? 26 : 8, height: 5, borderRadius: 3,
            border: "none", padding: 0, cursor: "pointer",
            background: i === page ? (p.isCover ? ACCENT : p.accent) : i < page ? "#444" : "#1e1e2a",
            transition: "all 0.4s ease",
          }} />
        ))}
      </div>

      {/* Card stack */}
      <div
        onTouchStart={onTouchStart} onTouchEnd={onTouchEnd} onWheel={onWheel}
        style={{
          perspective: 1200, position: "relative",
          width: "100%", maxWidth: 400, height: 720,
          opacity: introComplete ? 1 : 0,
          transform: introComplete ? "translateY(0)" : "translateY(20px)",
          transition: "all 0.8s ease 0.2s",
        }}
      >
        {PAGES.map((p, i) => (
          <Card key={p.id} page={p} index={i} currentPage={page}
            onNext={i === PAGES.length - 1 ? () => setPage(0) : next}
            onPrev={prev} total={PAGES.length}
          />
        ))}
      </div>

      <style>{`
        * { box-sizing: border-box; margin: 0; padding: 0; }
        html, body { background: #09090f; }

        @keyframes glitchIn {
          0% { opacity: 0; transform: translateY(10px) skewX(-5deg); }
          30% { opacity: 1; transform: translateY(-2px) skewX(3deg); }
          50% { transform: translateY(1px) skewX(-1deg); }
          100% { transform: translateY(0) skewX(0deg); }
        }
        @keyframes glitchR {
          0% { transform: translateX(0); }
          33% { transform: translateX(4px); }
          66% { transform: translateX(-2px); }
          100% { transform: translateX(0); }
        }
        @keyframes glitchL {
          0% { transform: translateX(0); }
          33% { transform: translateX(-4px); }
          66% { transform: translateX(3px); }
          100% { transform: translateX(0); }
        }
        @keyframes subtleGlitch {
          0%, 92%, 100% { transform: translate(0); }
          93% { transform: translate(2px, -1px); }
          94% { transform: translate(-2px, 1px); }
          95% { transform: translate(1px, 0); }
          96% { transform: translate(0); }
        }
        @keyframes microGlitchR {
          0%, 88%, 92%, 100% { transform: translateX(0); opacity: 0; }
          89% { transform: translateX(3px); opacity: 0.5; }
          91% { transform: translateX(-2px); opacity: 0.3; }
        }
        @keyframes microGlitchL {
          0%, 85%, 90%, 100% { transform: translateX(0); opacity: 0; }
          86% { transform: translateX(-3px); opacity: 0.5; }
          88% { transform: translateX(2px); opacity: 0.3; }
        }
        @keyframes typeIn {
          from { width: 0; }
          to { width: 320px; }
        }
        @keyframes loadBar {
          0% { width: 0%; }
          60% { width: 70%; }
          100% { width: 100%; }
        }
        @keyframes fadeUp {
          from { opacity: 0; transform: translateY(8px); }
          to { opacity: 1; transform: translateY(0); }
        }
        @keyframes wipeDown {
          from { transform: scaleY(0); transform-origin: top; }
          to { transform: scaleY(1); transform-origin: top; }
        }
      `}</style>
    </div>
  );
}

// ═══════════════════════════════════════════════════════
// INTRO SEQUENCE
// ═══════════════════════════════════════════════════════
const IntroSequence = ({ onComplete }) => {
  const [phase, setPhase] = useState(0);
  // 0=black, 1=glitch logo, 2=subtitle types in, 3=scanline wipe, 4=done

  useEffect(() => {
    const timers = [
      setTimeout(() => setPhase(1), 300),
      setTimeout(() => setPhase(2), 1600),
      setTimeout(() => setPhase(3), 2800),
      setTimeout(() => { setPhase(4); onComplete(); }, 3600),
    ];
    return () => timers.forEach(clearTimeout);
  }, [onComplete]);

  if (phase === 4) return null;

  return (
    <div style={{
      position: "fixed", inset: 0, zIndex: 9999, background: "#06060e",
      display: "flex", flexDirection: "column", alignItems: "center", justifyContent: "center",
      transition: "opacity 0.6s ease",
      opacity: phase === 3 ? 0 : 1,
    }}>
      {/* Scanline wipe */}
      {phase >= 3 && (
        <div style={{
          position: "absolute", top: 0, left: 0, right: 0,
          height: "100%", background: ACCENT, opacity: 0.08,
          animation: "wipeDown 0.8s ease-out forwards",
        }} />
      )}

      {/* Glitch MIA logo */}
      {phase >= 1 && (
        <div style={{ position: "relative" }}>
          <div style={{
            fontFamily: "'Instrument Sans', sans-serif",
            fontSize: 72, fontWeight: 800, color: "#fff",
            letterSpacing: -2, lineHeight: 1, position: "relative",
            animation: phase === 1 ? "glitchIn 0.4s ease-out forwards" : "none",
          }}>
            {/* Glitch layers */}
            <span style={{
              position: "absolute", top: 0, left: 0,
              color: "#66f5f0", clipPath: "inset(10% 0 60% 0)",
              animation: phase === 1 ? "glitchR 0.3s steps(3) 3" : "none",
            }}>M.I.A.</span>
            <span style={{
              position: "absolute", top: 0, left: 0,
              color: "#00e0d0", clipPath: "inset(50% 0 10% 0)",
              animation: phase === 1 ? "glitchL 0.3s steps(3) 3" : "none",
            }}>M.I.A.</span>
            M.I.A.
          </div>
        </div>
      )}

      {/* Subtitle typewriter */}
      {phase >= 2 && (
        <div style={{
          fontFamily: "'DM Mono', monospace", fontSize: 11,
          letterSpacing: 5, color: ACCENT, marginTop: 16, opacity: 0.8,
          animation: "typeIn 0.6s steps(28) forwards",
          overflow: "hidden", whiteSpace: "nowrap",
          borderRight: `2px solid ${ACCENT}`,
          width: 0,
          animationFillMode: "forwards",
        }}>
          MIAMI INTELLIGENCE AGGREGATOR
        </div>
      )}

      {/* Loading bar */}
      {phase >= 1 && (
        <div style={{
          position: "absolute", bottom: 80, left: "20%", right: "20%",
          height: 2, background: "#1a1a2a", borderRadius: 1, overflow: "hidden",
        }}>
          <div style={{
            height: "100%", background: ACCENT,
            animation: "loadBar 2.5s ease-out forwards",
            borderRadius: 1,
          }} />
        </div>
      )}

      {phase >= 1 && (
        <div style={{
          position: "absolute", bottom: 56,
          fontFamily: "'DM Mono', monospace", fontSize: 9,
          letterSpacing: 3, color: "#444",
          animation: "fadeUp 0.5s ease forwards",
        }}>
          ESTABLISHING SECURE CONNECTION...
        </div>
      )}
    </div>
  );
};


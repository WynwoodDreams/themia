const MiniBarChart = ({ data, accent, label }) => {
  const max = Math.max(...data);
  return (
    <div style={{ marginBottom: 2 }}>
      <div style={{
        fontFamily: "'DM Mono', monospace", fontSize: 10, color: "#999",
        marginBottom: 6, letterSpacing: 1.5, textTransform: "uppercase",
      }}>{label}</div>
      <div style={{ display: "flex", alignItems: "flex-end", gap: 3, height: 44 }}>
        {data.map((v, i) => (
          <div key={i} style={{
            flex: 1, height: `${(v / max) * 100}%`, minWidth: 0,
            background: `linear-gradient(to top, ${accent}, ${accent}55)`,
            borderRadius: "2px 2px 0 0",
          }} />
        ))}
      </div>
      <div style={{ height: 1, background: "#222", marginTop: 2 }} />
    </div>
  );
};

